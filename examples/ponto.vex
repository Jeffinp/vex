// `class` (= struct) define dados.
// `impl` ainda separado por ora — methods virão dentro de class na próxima fase.
// Construtor: `Ponto { x: 0.0, y: 0.0 }` (estilo named-fields).

class Ponto {
    x: float,
    y: float,
}

impl Ponto {
    def distancia(self, outro: Ponto) -> float {
        dx = self.x - outro.x
        dy = self.y - outro.y
        return sqrt(dx * dx + dy * dy)
    }
}

a = Ponto { x: 0.0, y: 0.0 }
b = Ponto { x: 3.0, y: 4.0 }
println(a.distancia(b))
