// Methods dentro de class — sem `impl` separado.
// Estilo Python total: `class` + `def` no mesmo bloco.

class Ponto {
    x: float,
    y: float,

    def distancia(self, outro: Ponto) -> float {
        dx = self.x - outro.x
        dy = self.y - outro.y
        return sqrt(dx * dx + dy * dy)
    }
}

a = Ponto { x: 0.0, y: 0.0 }
b = Ponto { x: 3.0, y: 4.0 }
println(a.distancia(b))
